# Copy to .env.dev and fill in your machine's values — .env.dev is gitignored
# since these are machine-specific (LAN IP of the local challenge server).
#
# Host caveats:
#   - iOS simulator: 127.0.0.1 reaches the host machine.
#   - Android emulator: use 10.0.2.2 (the emulator's host alias).
#   - Physical device: use the host machine's LAN IP, e.g. 192.168.x.x.

API_BASE_URL=http://127.0.0.1:8080
WS_BASE_URL=ws://127.0.0.1:8080
